#!/bin/sh
#
# Setup: git config core.hooksPath hooks

if [ -f "CLAUDE.md" ] && [ -f "AGENTS.md" ]; then
  if ! cmp -s CLAUDE.md AGENTS.md; then
    echo "ERROR: CLAUDE.md and AGENTS.md drifted apart." >&2
    exit 1
  fi
fi

if [ -x "bin/check-no-symlinks" ]; then
  if ! bin/check-no-symlinks; then
    exit 1
  fi
fi

plugin_versions_script="bin/plugin-versions"
if [ -x "$plugin_versions_script" ]; then
  PLUGIN_VERSIONS_GIT_CMD=$(ps -o args= -p $PPID 2>/dev/null || echo "git commit")
  export PLUGIN_VERSIONS_GIT_CMD
  if ! "$plugin_versions_script" --staged; then
    echo "ERROR: $plugin_versions_script --staged failed." >&2
    exit 1
  fi
fi

adapter_script="bin/plugin-adapters"
if [ -x "$adapter_script" ] && [ -f ".claude-plugin/marketplace.json" ]; then
  if ! "$adapter_script" build . >/dev/null; then
    echo "ERROR: $adapter_script build failed." >&2
    exit 1
  fi
  [ -f ".agents/plugins/marketplace.json" ] && git add -f ".agents/plugins/marketplace.json"
  if [ -d ".agents/plugins/generated" ]; then
    find ".agents/plugins/generated" -type f | while IFS= read -r generated_file; do
      git add -f "$generated_file"
    done
  fi
  find packages -path "*/.codex-plugin/plugin.json" -type f | while IFS= read -r codex_manifest; do
    git add "$codex_manifest"
  done
  find packages -path "*/skills/*/SKILL.claude.md" -type f | while IFS= read -r claude_skill; do
    git add "$(dirname "$claude_skill")/SKILL.md"
  done
  if ! "$adapter_script" check . >/dev/null; then
    echo "ERROR: $adapter_script check failed." >&2
    "$adapter_script" check . >&2
    exit 1
  fi
fi
